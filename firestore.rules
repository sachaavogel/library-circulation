rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isGuest() {
      return signedIn() &&
        request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    function patronKeysAreValid() {
      return request.resource.data.keys().hasOnly([
        "barcode",
        "name",
        "email",
        "createdAt",
        "lastSeenAt",
        "activeLoanCount",
        "activeHoldCount",
        "status"
      ]);
    }

    function guestPatronWriteAllowed(patronId) {
      return patronKeysAreValid() &&
        guestSessionExists() &&
        guestSessionPatron() == patronId &&
        request.resource.data.barcode == patronId;
    }

    function guestBookUpdateAllowed(bookId) {
      return request.resource.data.keys().hasOnly([
        "barcode",
        "title",
        "normalizedTitle",
        "status",
        "currentLoanId",
        "currentPatronBarcode",
        "holdCount",
        "holdQueue",
        "lastHoldPosition",
        "createdAt",
        "updatedAt"
      ]) &&
        request.resource.data.barcode == bookId &&
        request.resource.data.title == resource.data.title &&
        request.resource.data.normalizedTitle == resource.data.normalizedTitle &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function guestLoanCreateAllowed() {
      return request.resource.data.keys().hasOnly([
        "bookBarcode",
        "patronBarcode",
        "status",
        "checkedOutAt",
        "returnedAt",
        "createdByUid",
        "closedByUid"
      ]) &&
        request.resource.data.status == "active" &&
        request.resource.data.returnedAt == null &&
        request.resource.data.closedByUid == null &&
        request.resource.data.createdByUid == request.auth.uid;
    }

    function guestLoanUpdateAllowed() {
      return request.resource.data.keys().hasOnly([
        "bookBarcode",
        "patronBarcode",
        "status",
        "checkedOutAt",
        "returnedAt",
        "createdByUid",
        "closedByUid"
      ]) &&
        resource.data.status == "active" &&
        request.resource.data.status == "returned" &&
        request.resource.data.returnedAt != null &&
        request.resource.data.closedByUid == request.auth.uid &&
        request.resource.data.bookBarcode == resource.data.bookBarcode &&
        request.resource.data.patronBarcode == resource.data.patronBarcode;
    }

    function guestHoldCreateAllowed() {
      return request.resource.data.keys().hasOnly([
        "bookBarcode",
        "patronBarcode",
        "status",
        "createdAt",
        "fulfilledAt",
        "position"
      ]) &&
        request.resource.data.status == "queued" &&
        request.resource.data.fulfilledAt == null;
    }

    function guestHoldUpdateAllowed() {
      return request.resource.data.keys().hasOnly([
        "bookBarcode",
        "patronBarcode",
        "status",
        "createdAt",
        "fulfilledAt",
        "position"
      ]) &&
        resource.data.status == "queued" &&
        (request.resource.data.status == "fulfilled_auto_checkout" ||
          request.resource.data.status == "cancelled") &&
        request.resource.data.bookBarcode == resource.data.bookBarcode &&
        request.resource.data.patronBarcode == resource.data.patronBarcode;
    }

    function guestSessionExists() {
      return exists(/databases/$(database)/documents/guestSessions/$(request.auth.uid));
    }

    function guestSessionPatron() {
      return get(/databases/$(database)/documents/guestSessions/$(request.auth.uid)).data.patronBarcode;
    }

    function mailMessageValid() {
      return request.resource.data.message is map &&
        request.resource.data.message.keys().hasOnly(["subject", "text"]) &&
        request.resource.data.message.subject is string &&
        request.resource.data.message.text is string;
    }

    function mailRequestValid() {
      return request.resource.data.keys().hasOnly(["to", "message", "createdAt", "requestedByUid", "patronBarcode"]) &&
        request.resource.data.to is string &&
        mailMessageValid();
    }

    function guestMailAllowed() {
      return isGuest() &&
        guestSessionExists() &&
        mailRequestValid() &&
        request.resource.data.to ==
          get(/databases/$(database)/documents/patrons/$(guestSessionPatron())).data.email &&
        request.resource.data.patronBarcode == guestSessionPatron() &&
        request.resource.data.requestedByUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isAdmin();
    }

    match /guestSessions/{sessionId} {
      allow read, write: if isAdmin() || (signedIn() && request.auth.uid == sessionId);
    }

    match /patrons/{patronId} {
      allow get: if isAdmin() || isGuest();
      allow list: if isAdmin();
      allow create, update: if isAdmin() || (isGuest() && guestPatronWriteAllowed(patronId));
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow get: if isAdmin() || isGuest();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isGuest() && guestBookUpdateAllowed(bookId));
    }

    match /loans/{loanId} {
      allow get: if isAdmin() || (isGuest() && guestSessionExists() &&
        resource.data.patronBarcode == guestSessionPatron());
      allow list: if isAdmin() || (isGuest() && guestSessionExists() &&
        resource.data.patronBarcode == guestSessionPatron());
      allow delete: if isAdmin();
      allow create: if isAdmin() || (isGuest() && guestLoanCreateAllowed());
      allow update: if isAdmin() || (isGuest() && guestLoanUpdateAllowed());
    }

    match /holds/{holdId} {
      allow get: if isAdmin() || (isGuest() && guestSessionExists() &&
        resource.data.patronBarcode == guestSessionPatron());
      allow list: if isAdmin() || (isGuest() && guestSessionExists() &&
        resource.data.patronBarcode == guestSessionPatron());
      allow delete: if isAdmin();
      allow create: if isAdmin() || (isGuest() && guestHoldCreateAllowed());
      allow update: if isAdmin() || (isGuest() && guestHoldUpdateAllowed());
    }

    match /mail/{mailId} {
      allow create: if isAdmin() || guestMailAllowed();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
